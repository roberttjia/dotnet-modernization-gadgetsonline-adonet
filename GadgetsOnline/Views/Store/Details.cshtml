@model  GadgetsOnline.Models.Product

@{ ViewBag.Title = "Gadget - " + Model.Name; }

<h2>@Model.Name</h2>

<p>
    <img alt="@Model.Name" src="@Model.ProductArtUrl" />
</p>

<div id="album-details">
    <p>
        <em>Type:</em>
        @Model.Category.Name
    </p>
    <p>
        <em>Description:</em>
        @Model.Category.Description
    </p>
    <p>
        <em>Price:</em>$
        @String.Format("{0:F}", Model.Price)
    </p>
    <p class="button">
        @Html.ActionLink("Add to cart", "AddToCart",
                  "ShoppingCart", new { id = Model.ProductId }, "")
    </p>
</div>

@{
    var recommendations = ViewBag.FrequentlyBoughtTogether as List<GadgetsOnline.Models.Product>;
}
@if (recommendations != null && recommendations.Count > 0)
{
    <div id="frequently-bought-together">
        <h3><em>Frequently bought together</em></h3>
        <ul id="album-list">
            @foreach (var product in recommendations)
            {
                <li>
                    <a href="@Url.Action("Details", "Store", new { id = product.ProductId })">
                        <img alt="@product.Name" src="@product.ProductArtUrl" />
                        <span>@product.Name</span>
                    </a>
                </li>
            }
        </ul>
    </div>
}